API_SECRET_KEY=          # openssl rand -hex 32
SESSION_SECRET=          # openssl rand -hex 32
CF_TUNNEL_TOKEN=         # From Cloudflare Zero Trust dashboard

# Email skill — JSON array of IMAP/SMTP account configs
# Gmail app password: Google Account > Security > 2-Step Verification > App passwords
# Hotmail app password: Microsoft Account > Security > Advanced > App passwords
EMAIL_ACCOUNTS='[
  {"name":"Gmail","imap_host":"imap.gmail.com","imap_port":993,"smtp_host":"smtp.gmail.com","smtp_port":587,"user":"you@gmail.com","password":"xxxx-xxxx-xxxx-xxxx"},
  {"name":"Hotmail","imap_host":"imap-mail.outlook.com","imap_port":993,"smtp_host":"smtp-mail.outlook.com","smtp_port":587,"user":"you@hotmail.com","password":"xxxx-xxxx-xxxx-xxxx"},
  {"name":"improx","imap_host":"mail.improx.com","imap_port":993,"smtp_host":"smtp.improx.com","smtp_port":587,"user":"you@improx.com","password":"yourpassword"}
]'
EMAIL_DB_PATH=data/emails.db       # Local SQLite cache (same volume as sessions.db)
EMAIL_SYNC_DAYS_INITIAL=30         # Days back to fetch on first sync
EMAIL_MAX_RESULTS=10               # Max emails returned per check/search
